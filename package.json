{
  "name": "resume-analyzer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "type-check": "tsc --noEmit",
    "generate:icons": "node scripts/generate-pwa-icons.mjs",
    "supabase:link": "supabase link --project-ref qvfwskzszeaexsiwuqit --yes",
    "supabase:schema:pull": "supabase db pull --schema public",
    "supabase:types:live": "supabase gen types typescript --project-id qvfwskzszeaexsiwuqit --schema public > supabase-live-types.ts",
    "build:analyze": "ANALYZE=true npm run build",
    "docker:build": "docker build -t resume-analyzer .",
    "docker:run": "docker run -p 3000:3000 resume-analyzer",
    "docker:compose": "docker-compose up --build"
  },
  "dependencies": {
